{
	"name": "chrome-extension-vite-svelte",
	"version": "0.1.0",
	"private": true,
	"description": "Chrome extension boilerplate — Manifest V3 starter with Vite, Svelte, TypeScript, hot module reload, typed message passing, and service worker keepalive. Works in Chrome, Edge, and Firefox.",
	"keywords": [
		"chrome-extension",
		"browser-extension",
		"chrome-extension-boilerplate",
		"chrome-extension-starter",
		"chrome-extension-template",
		"extension-boilerplate",
		"svelte",
		"svelte-extension",
		"vite",
		"vite-plugin",
		"mv3",
		"manifest-v3",
		"typescript",
		"web-extension",
		"webextension",
		"crxjs",
		"hmr",
		"hot-reload"
	],
	"author": "graybear",
	"license": "MIT",
	"packageManager": "pnpm@10.33.2",
	"homepage": "https://github.com/graybearo/chrome-extension-vite-svelte#readme",
	"bugs": "https://github.com/graybearo/chrome-extension-vite-svelte/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/graybearo/chrome-extension-vite-svelte.git"
	},
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "svelte-check && vite build",
		"build:firefox": "BROWSER=firefox vite build",
		"preview": "vite preview",
		"typecheck": "svelte-check --tsconfig ./tsconfig.json",
		"zip": "node scripts/zip.mjs"
	},
	"dependencies": {
		"mv3-keepalive": "^1.0.0",
		"mv3-message-router": "^1.0.0",
		"svelte": "^4.2.19"
	},
	"devDependencies": {
		"@crxjs/vite-plugin": "^2.0.0-beta.28",
		"@sveltejs/vite-plugin-svelte": "^3.1.2",
		"@tsconfig/svelte": "^5.0.4",
		"@types/chrome": "^0.0.280",
		"@types/node": "^22.9.0",
		"svelte-check": "^4.0.5",
		"typescript": "^5.6.0",
		"vite": "^5.4.10"
	}
}
